# OpenClaw Agent Cluster Configuration

# Telegram Notification (optional)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# GitHub CLI (for PR creation and review)
# Make sure gh is installed and authenticated: gh auth login

# Agent Configuration
MAX_CONCURRENT_AGENTS=4
MONITOR_INTERVAL_MINUTES=10
TASK_RETENTION_DAYS=7

# Optional: Sentry Integration (for automatic error scanning)
SENTRY_ORG=your_org
SENTRY_PROJECT=your_project
SENTRY_AUTH_TOKEN=your_token

# Optional: Model API Keys (if not using CLI tools)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
